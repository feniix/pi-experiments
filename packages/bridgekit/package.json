{
  "name": "@feniix/bridgekit",
  "version": "0.2.0",
  "description": "BridgeKit defines TypeBox-backed tools once and adapts them to pi, MCP, and other hosts.",
  "keywords": [
    "pi",
    "mcp",
    "bridgekit",
    "portable-tools",
    "typebox"
  ],
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./pi": {
      "types": "./dist/src/pi.d.ts",
      "import": "./dist/src/pi.js"
    },
    "./mcp": {
      "types": "./dist/src/mcp.d.ts",
      "import": "./dist/src/mcp.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node ../../scripts/clean-package-dist.mjs && tsc -b tsconfig.json",
    "prepack": "npm run build && node ../../scripts/verify-bridgekit-dist.mjs"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.*",
    "!dist/**/*.typecheck.*",
    "!dist/tsconfig.tsbuildinfo",
    "README.md",
    "llms.txt",
    "examples/README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "typebox": "^1.1.31"
  },
  "license": "MIT"
}
