{
  "name": "@feniix/pi-text-utils",
  "version": "0.3.1",
  "description": "Tiny portable text utility tools exposed as both a pi extension and an MCP server.",
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "mcp",
    "portable-tools",
    "text-utils"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "pi-text-utils-mcp": "./dist/src/mcp-server.js"
  },
  "scripts": {
    "build": "npm run build --workspace @feniix/pi-portable-tools && node ../../scripts/clean-package-dist.mjs && tsc -b tsconfig.json",
    "prepack": "npm run build && node ../../scripts/vendor-pi-portable-tools-for-pack.mjs && node ../../scripts/verify-pi-text-utils-dist.mjs",
    "postpack": "node ../../scripts/cleanup-pi-text-utils-vendor.mjs"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.*",
    "!dist/tsconfig.tsbuildinfo",
    "prompts/",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./dist/extensions/index.js"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "dependencies": {
    "@feniix/pi-portable-tools": "0.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "typebox": "^1.1.31"
  },
  "bundleDependencies": [
    "@feniix/pi-portable-tools"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "license": "MIT"
}
