{
  "name": "@feniix/pi-portable-tools",
  "version": "0.1.0",
  "description": "Portable TypeBox-backed tool definitions and adapters for pi and MCP hosts.",
  "keywords": [
    "pi",
    "mcp",
    "portable-tools",
    "typebox"
  ],
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": { "types": "./dist/src/index.d.ts", "import": "./dist/src/index.js" },
    "./pi": { "types": "./dist/src/pi.d.ts", "import": "./dist/src/pi.js" },
    "./mcp": { "types": "./dist/src/mcp.d.ts", "import": "./dist/src/mcp.js" },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node ../../scripts/clean-package-dist.mjs && tsc -b tsconfig.json",
    "prepack": "npm run build && node ../../scripts/verify-pi-portable-tools-dist.mjs"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/**/*.test.*",
    "!dist/**/*.typecheck.*",
    "!dist/tsconfig.tsbuildinfo",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "typebox": "^1.1.31"
  },
  "license": "MIT"
}
