{
  "name": "pi-experiments",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "typecheck": "tsc -b tsconfig.json --noEmit",
    "test": "node --test packages/*/dist/**/*.test.js",
    "build": "tsc -b tsconfig.json",
    "mcp:text-utils:server": "npm run build && node packages/pi-text-utils/dist/src/mcp-server.js",
    "mcp:text-utils:smoke": "npm run build && node scripts/smoke-pi-text-utils-mcp.mjs",
    "mcp:text-utils:call": "npm run build && node scripts/call-pi-text-utils-mcp.mjs"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.19.17",
    "typescript": "^5.5.0",
    "typebox": "^1.1.31"
  }
}
