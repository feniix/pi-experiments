{
  "name": "pi-experiments",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "check": "npm run lint && npm run typecheck",
    "check:ci": "biome ci . && npm run typecheck",
    "clean": "node scripts/clean-workspace-dist.mjs",
    "typecheck": "tsc -b tsconfig.json",
    "test": "npm run build && node scripts/run-built-tests.mjs",
    "build": "npm run clean && tsc -b tsconfig.json",
    "mcp:text-utils:server": "npm run build && node packages/pi-text-utils/dist/src/mcp-server.js",
    "mcp:text-utils:smoke": "npm run build && node scripts/smoke-pi-text-utils-mcp.mjs",
    "mcp:text-utils:call": "npm run build && node scripts/call-pi-text-utils-mcp.mjs",
    "mcp:text-utils:parity": "npm run build && node scripts/compare-pi-text-utils-parity.mjs",
    "mcp:text-utils:package-smoke": "npm run build && node scripts/smoke-pi-text-utils-package.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22.19.17",
    "typescript": "^5.5.0",
    "typebox": "^1.1.31"
  }
}
